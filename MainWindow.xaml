<Window x:Class="VCDV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:render="clr-namespace:VCDV.Render"
        Title="Game View"
        Width="1280" Height="720"
        MinWidth="480" MinHeight="270"
        Background="{StaticResource BgWindow}"
        KeyDown="Window_KeyDown"
        Closing="Window_Closing">

  <Grid x:Name="RootGrid"
        Background="{StaticResource BgWindow}"
        MouseMove="RootGrid_MouseMove"
        MouseLeave="RootGrid_MouseLeave"
        SizeChanged="RootGrid_SizeChanged">

    <!-- ── Video display (native DXGI swap chain via HwndHost) ──── -->
    <!-- Overlays (FPS text / render info / cog) are drawn inside the   -->
    <!-- swap chain via D2D/DirectWrite, no airspace conflict possible. -->
    <render:D3D11VideoPanel x:Name="VideoDisplay"/>

    <!-- ── Sidebar in a Popup so it gets its own HWND and can paint -->
    <!-- OVER the HwndHost swap chain (airspace fix, like the cog).    -->
    <Popup x:Name="SidebarPopup"
           Placement="Absolute"
           AllowsTransparency="True"
           StaysOpen="True"
           IsOpen="False"
           PopupAnimation="None">

      <Border x:Name="SidebarPanel"
              Width="440"
              Background="{StaticResource BgPanel}"
              BorderThickness="0"
              CornerRadius="5"
              KeyDown="SidebarPanel_KeyDown">

        <Grid Width="440">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- Header -->
          <Grid Grid.Row="0" Margin="24,20,16,0">
            <TextBlock Text="Settings"
                       Foreground="{StaticResource FgPrimary}"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Content="✕"
                    Style="{StaticResource IconButton}"
                    HorizontalAlignment="Right"
                    Click="BtnCloseSidebar_Click"
                    Width="32" Height="32"
                    FontSize="14"
                    ToolTip="Close (Escape)"/>
          </Grid>

          <!-- Scrollable content -->
          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Margin="0,12,0,0">
            <StackPanel Margin="24,0,24,28">

              <!-- ── VIDEO ──────────────────────────────────── -->
              <TextBlock Text="Video Device" Style="{StaticResource FieldLabel}"/>
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="6"/>
                  <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="CbVideoDevice"
                          Grid.Column="0"
                          Style="{StaticResource DarkComboBox}"
                          SelectionChanged="CbVideoDevice_SelectionChanged"/>
                <Button x:Name="BtnRefreshDevices"
                        Style="{StaticResource IconButton}"
                        Grid.Column="2"
                        Content="↻"
                        Click="BtnRefreshDevices_Click"
                        ToolTip="Refresh device list"
                        Height="34" Width="34"
                        FontSize="17"
                        VerticalAlignment="Top"/>
              </Grid>

              <TextBlock Text="Resolution" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="CbResolution"
                        Style="{StaticResource DarkComboBox}"
                        SelectionChanged="CbResolution_SelectionChanged"
                        Margin="0,0,0,12">
                <ComboBoxItem Content="720p"/>
                <ComboBoxItem Content="1080p" IsSelected="True"/>
                <ComboBoxItem Content="1440p"/>
                <ComboBoxItem Content="4K"/>
              </ComboBox>

              <TextBlock Text="Frame Rate" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="CbFps"
                        Style="{StaticResource DarkComboBox}"
                        SelectionChanged="CbFps_SelectionChanged"
                        Margin="0,0,0,6">
                <ComboBoxItem Content="30 FPS"/>
                <ComboBoxItem Content="60 FPS" IsSelected="True"/>
                <ComboBoxItem Content="120 FPS"/>
                <ComboBoxItem Content="Custom"/>
              </ComboBox>

              <!-- Custom FPS (shown only when Custom selected) -->
              <Grid x:Name="CustomFpsRow" Visibility="Collapsed" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SlCustomFps"
                        Grid.Column="0"
                        Minimum="30" Maximum="240" Value="60"
                        TickFrequency="10" IsSnapToTickEnabled="True"
                        Style="{StaticResource DarkSlider}"
                        ValueChanged="SlCustomFps_ValueChanged"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="TbCustomFpsValue"
                           Grid.Column="1"
                           Text="60"
                           Foreground="{StaticResource FgPrimary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="13"/>
              </Grid>

              <TextBlock x:Name="TbHighFpsWarning"
                         Text="⚠ Above 60 FPS may require MJPEG and extra CPU."
                         Foreground="{StaticResource Warning}"
                         FontSize="11"
                         TextWrapping="Wrap"
                         Margin="0,0,0,10"
                         Visibility="Collapsed"/>

              <!-- Separator: VIDEO ↔ AUDIO -->
              <Border Height="1"
                      Background="{StaticResource BorderControl}"
                      Margin="0,30,0,30"/>

              <!-- ── AUDIO ──────────────────────────────────── -->
              <TextBlock Text="Audio Input" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="CbAudioInput"
                        Style="{StaticResource DarkComboBox}"
                        SelectionChanged="CbAudioInput_SelectionChanged"
                        Margin="0,0,0,12"/>

              <TextBlock Text="Audio Output" Style="{StaticResource FieldLabel}"/>
              <ComboBox x:Name="CbAudioOutput"
                        Style="{StaticResource DarkComboBox}"
                        SelectionChanged="CbAudioOutput_SelectionChanged"
                        Margin="0,0,0,12"/>

              <TextBlock Text="Volume" Style="{StaticResource FieldLabel}"/>
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SlVolume"
                        Grid.Column="0"
                        Minimum="0" Maximum="100" Value="100"
                        Style="{StaticResource DarkSlider}"
                        ValueChanged="SlVolume_ValueChanged"
                        VerticalAlignment="Center"/>
                <TextBlock x:Name="TbVolumeValue"
                           Grid.Column="1"
                           Text="100%"
                           Foreground="{StaticResource FgPrimary}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="13"/>
              </Grid>

              <!-- Separator: AUDIO ↔ Checkboxes -->
              <Border Height="1"
                      Background="{StaticResource BorderControl}"
                      Margin="0,30,0,30"/>

              <CheckBox x:Name="ChkOverlay"
                        Style="{StaticResource AccentCheckBox}"
                        Content="Show FPS overlay"
                        IsChecked="True"
                        Checked="ChkOverlay_CheckedChanged"
                        Unchecked="ChkOverlay_CheckedChanged"
                        Margin="0,0,0,12"/>

              <CheckBox x:Name="ChkRenderInfo"
                        Style="{StaticResource AccentCheckBox}"
                        Content="Show render info"
                        IsChecked="False"
                        Checked="ChkRenderInfo_CheckedChanged"
                        Unchecked="ChkRenderInfo_CheckedChanged"/>

              <!-- Separator: Checkboxes ↔ Buttons -->
              <Border Height="1"
                      Background="{StaticResource BorderControl}"
                      Margin="0,30,0,30"/>

              <!-- ── Actions ────────────────────────────────── -->
              <Button x:Name="BtnFullscreen"
                      Style="{StaticResource GreenButton}"
                      Content="Enter Fullscreen"
                      Click="BtnFullscreen_Click"
                      Height="38"
                      Margin="0,0,0,12"/>

              <Button Style="{StaticResource RedButton}"
                      Content="Exit Game View"
                      Click="BtnExit_Click"
                      Height="38"
                      Margin="0,0,0,14"/>

              <TextBlock Text="Press Escape to close"
                         Foreground="{StaticResource FgHint}"
                         FontSize="11"
                         HorizontalAlignment="Center"/>

            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Popup>

  </Grid>
</Window>
